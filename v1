<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Adorable Hijabi Friend</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Playfair+Display:ital,wght@1,700&display=swap" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/cooper-black" rel="stylesheet">
  <style>
    /* ─── Reset & Base ─────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito', sans-serif;
      background: #EDC1BB;
      color: #333;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Nav ───────────────────────────────────────── */
    .nav {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      padding: 1rem 2.5rem;
      background: #E7DFE1;
      border-bottom: 2px solid #EDC1BB;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 13px;
      font-weight: 700;
      color: #7e98a8;
      text-decoration: none;
      letter-spacing: 0.5px;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #CD7250; }

    /* Mobile nav */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: #7e98a8;
      border-radius: 2px;
      transition: all 0.3s;
    }
    .mobile-menu {
      display: none;
      flex-direction: column;
      background: #E7DFE1;
      border-bottom: 2px solid #EDC1BB;
      padding: 0;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.3s ease, padding 0.3s ease;
    }
    .mobile-menu.open {
      max-height: 200px;
      padding: 1rem 0;
    }
    .mobile-menu a {
      font-size: 14px;
      font-weight: 700;
      color: #7e98a8;
      text-decoration: none;
      padding: 0.6rem 1.5rem;
      display: block;
    }
    .mobile-menu a:hover { color: #CD7250; }

    /* ─── Hero ──────────────────────────────────────── */
    .hero {
      background: #EDC1BB;
      padding: 5rem 2rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: #E99075;
      opacity: 0.12;
      top: -100px; right: -80px;
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      width: 220px; height: 220px;
      border-radius: 50%;
      background: #fff;
      opacity: 0.07;
      bottom: -50px; left: 40px;
      pointer-events: none;
    }
    .hero-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 3px;
      color: #CD7250;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .hero-title {
      font-family: 'Cooper Black', 'Cooper Std', serif;
      font-size: clamp(40px, 8vw, 72px);
      color: #fff;
      line-height: 1.08;
      text-shadow: 0 6px 0 #CD7250;
      margin-bottom: 0.75rem;
    }
    .hero-sub {
      font-family: 'Playfair Display', serif;
      font-size: clamp(16px, 3vw, 20px);
      color: #CD7250;
      font-style: italic;
      font-weight: 700;
      margin-bottom: 2.25rem;
    }
    .cta-btn {
      display: inline-block;
      background: #CD7250;
      color: #fff;
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 16px;
      padding: 15px 38px;
      border-radius: 50px;
      border: none;
      cursor: pointer;
      box-shadow: 0 5px 0 #9a4f2f;
      text-decoration: none;
      transition: transform 0.1s, box-shadow 0.1s;
      letter-spacing: 0.3px;
    }
    .cta-btn:hover {
      transform: translateY(2px);
      box-shadow: 0 3px 0 #9a4f2f;
    }
    .cta-btn:active {
      transform: translateY(4px);
      box-shadow: 0 1px 0 #9a4f2f;
    }

    /* ─── Marquee ───────────────────────────────────── */
    .marquee-strip {
      background: #7e98a8;
      padding: 12px 0;
      overflow: hidden;
      white-space: nowrap;
    }
    .marquee-track {
      display: inline-flex;
      animation: marquee 20s linear infinite;
    }
    .marquee-track span {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2.5px;
      color: #fff;
      text-transform: uppercase;
      padding: 0 1.5rem;
    }
    .marquee-track .dot { color: #EDC1BB; }
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ─── Story ─────────────────────────────────────── */
    .story {
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: #fff;
    }
    .story-image-side {
      background: #EDC1BB;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3.5rem 2.5rem;
      min-height: 420px;
    }
    .story-placeholder {
      width: 100%;
      max-width: 280px;
      aspect-ratio: 3/4;
      background: #E99075;
      border-radius: 24px;
      opacity: 0.35;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .story-placeholder span {
      font-size: 12px;
      font-weight: 700;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-align: center;
      line-height: 1.8;
    }
    .story-text {
      padding: 3.5rem 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-left: 4px solid #EDC1BB;
    }
    .story-tag {
      font-size: 10px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #7e98a8;
      font-weight: 700;
      margin-bottom: 1.1rem;
    }
    .story-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(24px, 3vw, 32px);
      font-style: italic;
      font-weight: 700;
      color: #CD7250;
      line-height: 1.25;
      margin-bottom: 1.25rem;
    }
    .story-body {
      font-size: 14px;
      color: #999;
      line-height: 1.85;
      margin-bottom: 2rem;
    }
    .story-body em { color: #CD7250; font-style: italic; }
    .story-link {
      display: inline-block;
      background: #EDC1BB;
      color: #CD7250;
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 13px;
      padding: 11px 26px;
      border-radius: 50px;
      text-decoration: none;
      border: 2px solid #CD7250;
      letter-spacing: 0.3px;
      transition: background 0.2s, color 0.2s;
      align-self: flex-start;
    }
    .story-link:hover {
      background: #CD7250;
      color: #fff;
    }

    /* ─── Footer ────────────────────────────────────── */
    .footer {
      background: #7e98a8;
      padding: 3.5rem 2rem 2.5rem;
      text-align: center;
    }
    .footer-title {
      font-family: 'Cooper Black', 'Cooper Std', serif;
      font-size: 26px;
      color: #fff;
      margin-bottom: 0.4rem;
    }
    .footer-sub {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-style: italic;
      color: #E7DFE1;
      margin-bottom: 2rem;
    }
    .footer-socials {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }
    .social-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #adc2cf;
      color: #fff;
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 13px;
      padding: 11px 24px;
      border-radius: 50px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .social-btn:hover {
      background: #E7DFE1;
      color: #7e98a8;
      transform: translateY(-2px);
    }
    .footer-divider {
      border: none;
      border-top: 1px solid #adc2cf;
      margin: 0 auto 2rem;
      width: 50%;
    }
    .contact-box {
      background: #adc2cf;
      border-radius: 20px;
      display: inline-block;
      padding: 18px 36px;
    }
    .contact-label {
      font-size: 13px;
      color: #fff;
      font-weight: 900;
      margin-bottom: 4px;
    }
    .contact-email {
      font-size: 14px;
      color: #fff;
      font-weight: 700;
    }
    .footer-copy {
      font-size: 11px;
      color: #dde8ef;
      margin-top: 2rem;
      opacity: 0.7;
    }

    /* ─── Responsive ────────────────────────────────── */
    @media (max-width: 768px) {
      /* Nav */
      .nav { justify-content: space-between; padding: 1rem 1.25rem; }
      .nav-links { display: none; }
      .hamburger { display: flex; }

      /* Hero */
      .hero { padding: 3rem 1.25rem 2.5rem; }
      .hero-title { font-size: clamp(34px, 10vw, 48px); }

      /* Story */
      .story { grid-template-columns: 1fr; }
      .story-image-side {
        padding: 2rem 1.25rem;
        min-height: 220px;
      }
      .story-placeholder {
        max-width: 180px;
        aspect-ratio: 1/1;
        border-radius: 16px;
      }
      .story-text {
        padding: 2rem 1.25rem;
        border-left: none;
        border-top: 4px solid #EDC1BB;
      }

      /* Footer */
      .footer { padding: 2.5rem 1.25rem 2rem; }
      .footer-socials {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }
      .social-btn { justify-content: center; }
      .footer-divider { width: 80%; }
      .contact-box { padding: 14px 24px; }
    }

    @media (max-width: 480px) {
      .hero-eyebrow { font-size: 9px; letter-spacing: 2px; }
      .story-heading { font-size: 22px; }
      .footer-title { font-size: 22px; }
      .footer-sub { font-size: 14px; }
    }
  </style>
</head>
